; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="TowersLastStand3D"
run/main_scene="res://scenes/ui/world_map.tscn"
config/features=PackedStringArray("4.4", "Mobile")
config/icon="res://icon.svg"

[autoload]

Constants="*res://autoloads/constants.gd"
EventBus="*res://autoloads/event_bus.gd"
GameState="*res://autoloads/game_state.gd"
MetaManager="*res://autoloads/meta_manager.gd"
SpellRegistry="*res://autoloads/spell_registry.gd"
ObjectPool="*res://autoloads/object_pool.gd"
AudioManager="*res://autoloads/audio_manager.gd"

[display]

window/size/viewport_width=1080
window/size/viewport_height=1920
window/size/window_width_override=662
window/size/window_height_override=900
window/stretch/mode="canvas_items"

[rendering]

renderer/rendering_method="mobile"
lights_and_shadows/directional_shadow/soft_shadow_filter_quality.mobile=1
lights_and_shadows/positional_shadow/soft_shadow_filter_quality.mobile=1
